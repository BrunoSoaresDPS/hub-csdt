# Vercel Postgres — copie os valores do painel Vercel > Storage > seu banco > .env.local
POSTGRES_PRISMA_URL=postgresql://USER:PASS@HOST:5432/DATABASE?pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgresql://USER:PASS@HOST:5432/DATABASE

# JWT secret — use uma string longa e aleatória
JWT_SECRET=troque-por-uma-string-secreta-longa

# Desenvolvimento local (opcional, se não usar Vercel Postgres)
# DATABASE_URL=postgresql://localhost:5432/hub_csdt
